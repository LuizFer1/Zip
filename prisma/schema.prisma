datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model Event {
  id         String  @id
  channelId  String
  author     String
  timestamp  Int
  type       String
  payload    Bytes
  prev       Json
  signature  String

  @@index([channelId])
  @@index([timestamp])
  @@index([author])
  @@index([channelId, timestamp])
}

model Channel {
  id        String @id
  creator   String
  createdAt Int
}

model Identity {
  publicKey String @id
  username  String?
  avatar    String?
  nodeId    String?
  updatedAt Int

  @@index([nodeId])
}

model LocalIdentity {
  id         Int    @id @default(1)
  publicKey  String
  privateKey String
  avatar    String?
  username  String
  createdAt  Int
}

model ChannelKey {
  channelId     String @id
  publicKey     String
  privateKey    String?
  encryptionKey String

  @@index([publicKey])
}

model ChannelHead {
  channelId String
  eventId   String

  @@id([channelId, eventId])
}

model Peer {
  publicKey String @id
  lastSeen  Int
  addresses String

  @@index([lastSeen])
}
